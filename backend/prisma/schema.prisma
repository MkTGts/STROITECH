generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  supplier
  builder
  equipment
  client
  moderator
}

enum ListingStatus {
  active
  archived
  moderation
}

enum ObjectStatus {
  draft
  active
  completed
  archived
}

enum StageType {
  foundation
  walls
  roof
  engineering
  finish
  furniture
}

enum StageStatus {
  pending
  in_progress
  completed
}

enum ContextType {
  listing
  object
  profile
}

enum SubscriptionPlan {
  free
  basic
  premium
}

enum SubscriptionStatusEnum {
  active
  expired
  cancelled
}

enum NotificationType {
  new_object
  message
  tender
  system
  new_follower
  event_rsvp
  event_reminder
}

enum EventRsvpStatus {
  going
  maybe
  not_going
}

enum FeedPostStatus {
  published
}

enum FeedPostKind {
  article
  wall
  share
}

enum ShareTargetType {
  feed_post
  listing
  construction_object
}

enum CommunityMemberRole {
  admin
  moderator
  member
}

enum ContentReportTargetType {
  feed_post
  feed_comment
}

enum ContentReportStatus {
  pending
  closed
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  phone        String
  passwordHash String   @map("password_hash")
  role         UserRole
  name         String
  region       String?
  companyName  String?  @map("company_name")
  description  String?  @db.Text
  avatarUrl    String?  @map("avatar_url")
  isVerified   Boolean  @default(false) @map("is_verified")
  verifiedAt       DateTime? @map("verified_at")
  verifiedById     String?   @map("verified_by_id") @db.Uuid
  verificationNote String?   @map("verification_note") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  verifiedBy             User?                @relation("UserVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verificationsGranted   User[]               @relation("UserVerifier")
  verificationAuditsAsTarget VerificationAudit[] @relation("VerificationAuditTarget")
  verificationAuditsAsActor  VerificationAudit[] @relation("VerificationAuditActor")

  managers              Manager[]
  listings              Listing[]
  objects               ConstructionObject[]
  sentMessages          Message[]
  conversationsAsUser1  Conversation[]       @relation("ConversationParticipant1")
  conversationsAsUser2  Conversation[]       @relation("ConversationParticipant2")
  subscriptions         Subscription[]
  notifications         Notification[]
  feedPosts             FeedPost[]
  feedPostLikes         FeedPostLike[]
  feedComments          FeedComment[]
  feedCommentLikes      FeedCommentLike[]
  feedPostViews         FeedPostView[]
  outgoingFollows       UserFollow[]         @relation("OutgoingFollows")
  incomingFollows       UserFollow[]         @relation("IncomingFollows")
  photoAlbums           PhotoAlbum[]
  communitiesCreated    Community[]          @relation("CommunityCreator")
  communityMembers      CommunityMember[]
  eventsCreated         Event[]
  eventRsvps            EventRsvp[]
  contentReportsFiled   ContentReport[] @relation("ContentReportReporter")
  contentReportsClosed  ContentReport[] @relation("ContentReportClosedBy")

  @@map("users")
}

model Community {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  region      String?  @db.VarChar(200)
  creatorId   String   @map("creator_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator   User              @relation("CommunityCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members   CommunityMember[]
  feedPosts FeedPost[]
  albums    PhotoAlbum[]
  events    Event[]

  @@index([region])
  @@index([createdAt(sort: Desc)])
  @@map("communities")
}

model CommunityMember {
  id          String              @id @default(uuid()) @db.Uuid
  communityId String              @map("community_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  role        CommunityMemberRole @default(member)
  createdAt   DateTime            @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

model FeedTag {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  postTags FeedPostTag[]

  @@map("feed_tags")
}

model FeedPostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  FeedTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("feed_post_tags")
}

model UserFollow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("OutgoingFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("IncomingFollows", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model VerificationAudit {
  id        String   @id @default(uuid()) @db.Uuid
  targetId  String   @map("target_id") @db.Uuid
  actorId   String   @map("actor_id") @db.Uuid
  action    String   @db.VarChar(20)
  note      String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  target User @relation("VerificationAuditTarget", fields: [targetId], references: [id], onDelete: Cascade)
  actor  User @relation("VerificationAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@index([createdAt(sort: Desc)])
  @@map("verification_audits")
}

model FeedPost {
  id             String              @id @default(uuid()) @db.Uuid
  authorId       String              @map("author_id") @db.Uuid
  kind           FeedPostKind        @default(article)
  title          String              @db.VarChar(200)
  slug           String?             @unique @db.VarChar(220)
  excerpt        String?             @db.VarChar(500)
  body           String              @db.Text
  coverImageUrl  String?             @map("cover_image_url")
  attachments    Json                @default("[]")
  /** Для kind=share: тип и id оригинала (пост / объявление / объект). */
  shareTarget    ShareTargetType?    @map("share_target")
  shareTargetId  String?             @map("share_target_id") @db.Uuid
  /** UUID пользователей из токенов [[mention:uuid]] в тексте. */
  mentions       Json                @default("[]")
  status         FeedPostStatus      @default(published)
  publishedAt    DateTime            @default(now()) @map("published_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  communityId    String?             @map("community_id") @db.Uuid

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  likes    FeedPostLike[]
  comments FeedComment[]
  views    FeedPostView[]
  postTags FeedPostTag[]

  @@index([authorId])
  @@index([publishedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, kind, publishedAt(sort: Desc)])
  @@index([communityId, publishedAt(sort: Desc)])
  @@map("feed_posts")
}

model FeedPostView {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @map("post_id") @db.Uuid
  viewerId       String   @map("viewer_id") @db.Uuid
  firstViewedAt  DateTime @default(now()) @map("first_viewed_at")

  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewer User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerId])
  @@index([postId])
  @@map("feed_post_views")
}

model FeedPostLike {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("feed_post_likes")
}

model FeedComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    FeedPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  FeedComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies FeedComment[]     @relation("CommentReplies")
  likes   FeedCommentLike[]

  @@index([postId])
  @@index([postId, createdAt])
  @@index([parentId])
  @@map("feed_comments")
}

model FeedCommentLike {
  id        String   @id @default(uuid()) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  comment FeedComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@map("feed_comment_likes")
}

model Manager {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  name     String
  phone    String
  position String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("managers")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?      @map("parent_id")
  icon     String?
  type     String

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  categoryId  Int           @map("category_id")
  title       String
  description String       @db.Text
  region      String?
  photos      Json          @default("[]")
  price       Decimal?      @db.Decimal(12, 2)
  isPromoted  Boolean       @default(false) @map("is_promoted")
  viewCount   Int           @default(0) @map("view_count")
  status      ListingStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@map("listings")
}

model ConstructionObject {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  title        String
  description  String?      @db.Text
  region       String?
  currentStage StageType    @default(foundation) @map("current_stage")
  status       ObjectStatus @default(active)
  isVisible    Boolean      @default(true) @map("is_visible")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages ObjectStage[]
  photoAlbums PhotoAlbum[]

  @@index([userId])
  @@index([status])
  @@map("construction_objects")
}

model PhotoAlbum {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  coverUrl    String?  @map("cover_url")
  objectId    String?  @map("object_id") @db.Uuid
  communityId String?  @map("community_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner     User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  object    ConstructionObject? @relation(fields: [objectId], references: [id], onDelete: SetNull)
  community Community?          @relation(fields: [communityId], references: [id], onDelete: SetNull)
  photos    AlbumPhoto[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([objectId])
  @@index([communityId])
  @@map("photo_albums")
}

model AlbumPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  albumId   String   @map("album_id") @db.Uuid
  url       String
  caption   String?  @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  album PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, sortOrder])
  @@map("album_photos")
}

model ObjectStage {
  id               String      @id @default(uuid()) @db.Uuid
  objectId         String      @map("object_id") @db.Uuid
  stageType        StageType   @map("stage_type")
  status           StageStatus @default(pending)
  materialsRequest String?     @map("materials_request") @db.Text
  buildersRequest  String?     @map("builders_request") @db.Text
  equipmentRequest String?     @map("equipment_request") @db.Text
  updatedAt        DateTime    @updatedAt @map("updated_at")

  object ConstructionObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@map("object_stages")
}

model Conversation {
  id             String      @id @default(uuid()) @db.Uuid
  participant1Id String      @map("participant1_id") @db.Uuid
  participant2Id String      @map("participant2_id") @db.Uuid
  contextType    ContextType @map("context_type")
  contextId      String?     @map("context_id") @db.Uuid
  lastMessageAt  DateTime?   @map("last_message_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  participant1 User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id, contextType, contextId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model Subscription {
  id        String                 @id @default(uuid()) @db.Uuid
  userId    String                 @map("user_id") @db.Uuid
  plan      SubscriptionPlan       @default(free)
  status    SubscriptionStatusEnum @default(active)
  startedAt DateTime               @default(now()) @map("started_at")
  expiresAt DateTime               @map("expires_at")
  autoRenew Boolean                @default(true) @map("auto_renew")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  content   String           @db.Text
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  startsAt    DateTime @map("starts_at")
  isOnline    Boolean  @default(false) @map("is_online")
  venue       String?  @db.VarChar(500)
  creatorId   String   @map("creator_id") @db.Uuid
  communityId String?  @map("community_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator   User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  rsvps     EventRsvp[]

  @@index([startsAt])
  @@index([communityId, startsAt])
  @@map("events")
}

model EventRsvp {
  id                 String          @id @default(uuid()) @db.Uuid
  eventId            String          @map("event_id") @db.Uuid
  userId             String          @map("user_id") @db.Uuid
  status             EventRsvpStatus
  reminderNotifiedAt DateTime?       @map("reminder_notified_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_rsvps")
}

model ContentReport {
  id          String                  @id @default(uuid()) @db.Uuid
  reporterId  String                  @map("reporter_id") @db.Uuid
  targetType  ContentReportTargetType @map("target_type")
  targetId    String                  @map("target_id") @db.Uuid
  details     String?                 @db.Text
  status      ContentReportStatus     @default(pending)
  createdAt   DateTime                @default(now()) @map("created_at")
  closedAt    DateTime?               @map("closed_at")
  closedById  String?                 @map("closed_by_id") @db.Uuid

  reporter User  @relation("ContentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  closedBy User? @relation("ContentReportClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([reporterId, targetType, targetId])
  @@index([status, createdAt(sort: Desc)])
  @@map("content_reports")
}
