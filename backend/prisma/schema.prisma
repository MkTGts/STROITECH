generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  supplier
  builder
  equipment
  client
  moderator
}

enum ListingStatus {
  active
  archived
  moderation
}

enum ObjectStatus {
  draft
  active
  completed
  archived
}

enum StageType {
  foundation
  walls
  roof
  engineering
  finish
  furniture
}

enum StageStatus {
  pending
  in_progress
  completed
}

enum ContextType {
  listing
  object
  profile
}

enum SubscriptionPlan {
  free
  basic
  premium
}

enum SubscriptionStatusEnum {
  active
  expired
  cancelled
}

enum NotificationType {
  new_object
  message
  tender
  system
}

enum FeedPostStatus {
  published
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  phone        String
  passwordHash String   @map("password_hash")
  role         UserRole
  name         String
  region       String?
  companyName  String?  @map("company_name")
  description  String?  @db.Text
  avatarUrl    String?  @map("avatar_url")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  managers              Manager[]
  listings              Listing[]
  objects               ConstructionObject[]
  sentMessages          Message[]
  conversationsAsUser1  Conversation[]       @relation("ConversationParticipant1")
  conversationsAsUser2  Conversation[]       @relation("ConversationParticipant2")
  subscriptions         Subscription[]
  notifications         Notification[]
  feedPosts             FeedPost[]
  feedPostLikes         FeedPostLike[]
  feedComments          FeedComment[]
  feedPostViews         FeedPostView[]

  @@map("users")
}

model FeedPost {
  id             String          @id @default(uuid()) @db.Uuid
  authorId       String          @map("author_id") @db.Uuid
  title          String          @db.VarChar(200)
  slug           String?         @unique @db.VarChar(220)
  excerpt        String?         @db.VarChar(500)
  body           String          @db.Text
  coverImageUrl  String?         @map("cover_image_url")
  status         FeedPostStatus  @default(published)
  publishedAt    DateTime        @default(now()) @map("published_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes    FeedPostLike[]
  comments FeedComment[]
  views    FeedPostView[]

  @@index([authorId])
  @@index([publishedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@map("feed_posts")
}

model FeedPostView {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @map("post_id") @db.Uuid
  viewerId       String   @map("viewer_id") @db.Uuid
  firstViewedAt  DateTime @default(now()) @map("first_viewed_at")

  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewer User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerId])
  @@index([postId])
  @@map("feed_post_views")
}

model FeedPostLike {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("feed_post_likes")
}

model FeedComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post   FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, createdAt])
  @@map("feed_comments")
}

model Manager {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  name     String
  phone    String
  position String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("managers")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?      @map("parent_id")
  icon     String?
  type     String

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  categoryId  Int           @map("category_id")
  title       String
  description String       @db.Text
  region      String?
  photos      Json          @default("[]")
  price       Decimal?      @db.Decimal(12, 2)
  isPromoted  Boolean       @default(false) @map("is_promoted")
  status      ListingStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@map("listings")
}

model ConstructionObject {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  title        String
  description  String?      @db.Text
  region       String?
  currentStage StageType    @default(foundation) @map("current_stage")
  status       ObjectStatus @default(active)
  isVisible    Boolean      @default(true) @map("is_visible")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages ObjectStage[]

  @@index([userId])
  @@index([status])
  @@map("construction_objects")
}

model ObjectStage {
  id               String      @id @default(uuid()) @db.Uuid
  objectId         String      @map("object_id") @db.Uuid
  stageType        StageType   @map("stage_type")
  status           StageStatus @default(pending)
  materialsRequest String?     @map("materials_request") @db.Text
  buildersRequest  String?     @map("builders_request") @db.Text
  equipmentRequest String?     @map("equipment_request") @db.Text

  object ConstructionObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@map("object_stages")
}

model Conversation {
  id             String      @id @default(uuid()) @db.Uuid
  participant1Id String      @map("participant1_id") @db.Uuid
  participant2Id String      @map("participant2_id") @db.Uuid
  contextType    ContextType @map("context_type")
  contextId      String?     @map("context_id") @db.Uuid
  lastMessageAt  DateTime?   @map("last_message_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  participant1 User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id, contextType, contextId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model Subscription {
  id        String                 @id @default(uuid()) @db.Uuid
  userId    String                 @map("user_id") @db.Uuid
  plan      SubscriptionPlan       @default(free)
  status    SubscriptionStatusEnum @default(active)
  startedAt DateTime               @default(now()) @map("started_at")
  expiresAt DateTime               @map("expires_at")
  autoRenew Boolean                @default(true) @map("auto_renew")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  content   String           @db.Text
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
