DATABASE_URL=postgresql://postgres:postgres@localhost:5432/objekty_online
JWT_SECRET=your-super-secret-jwt-key-change-in-production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
BACKEND_PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# S3 (Object Storage) for uploads/avatars
# If set, files will be uploaded to S3 instead of local ./uploads
# S3_BUCKET=your-bucket
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=ru-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# Optional public base URL for CDN/custom domain:
# S3_PUBLIC_URL=https://cdn.example.com
